{
  "name": "java-analyzer",
  "version": "1.0.0",
  "description": "The fast Java/Kotlin lsp",
  "author": "cubewhy",
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:java",
    "onLanguage:kotlin",
    "onCommand:java-analyzer.setJdkPath",
    "onCommand:java-analyzer.setVineflowerPath",
    "onCommand:java-analyzer.setCfrPath",
    "onCommand:java-analyzer.selectDecompilerBackend",
    "onCommand:java-analyzer.setServerPath"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kotlin",
        "aliases": [
          "Kotlin",
          "kotlin"
        ],
        "extensions": [
          ".kt",
          ".kts"
        ]
      }
    ],
    "commands": [
      {
        "command": "java-analyzer.setJdkPath",
        "title": "Java Analyzer: Set JDK Path"
      },
      {
        "command": "java-analyzer.setVineflowerPath",
        "title": "Java Analyzer: Set Vineflower Path"
      },
      {
        "command": "java-analyzer.setCfrPath",
        "title": "Java Analyzer: Set CFR Path"
      },
      {
        "command": "java-analyzer.selectDecompilerBackend",
        "title": "Java Analyzer: Select Decompiler Backend"
      },
      {
        "command": "java-analyzer.setServerPath",
        "title": "Java Analyzer: Set Server Path"
      }
    ],
    "configuration": {
      "title": "Java Analyzer",
      "properties": {
        "java-analyzer.jdkPath": {
          "type": "string",
          "default": "",
          "description": "Path to the JDK home directory used by the Java analyzer. If empty, the backend falls back to `java` on PATH."
        },
        "java-analyzer.decompilerBackend": {
          "type": "string",
          "default": "vineflower",
          "enum": ["vineflower", "cfr"],
          "enumDescriptions": [
            "Use the Vineflower decompiler backend.",
            "Use the CFR decompiler backend."
          ],
          "description": "Select the decompiler backend."
        },
        "java-analyzer.vineflowerPath": {
          "type": "string",
          "default": "",
          "description": "Optional custom path to the Vineflower jar. If empty, Java Analyzer uses bundled Vineflower."
        },
        "java-analyzer.cfrPath": {
          "type": "string",
          "default": "",
          "description": "Optional custom path to the CFR jar. If empty, Java Analyzer uses bundled CFR."
        },
        "java-analyzer.serverPath": {
          "type": "string",
          "default": "",
          "description": "Optional custom path to the LSP backend executable. If set, use this backend. If empty, use bundled backend, or `cargo run` in development."
        },
        "java-analyzer.logLevel": {
          "type": "string",
          "default": "info",
          "description": "Tracing log level (EnvFilter syntax) passed to the language server via JAVA_ANALYZER_LOG."
        }
      }
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "prepare:decompilers": "node scripts/prepare-decompilers.mjs",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production && pnpm run prepare:decompilers",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.7.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22",
    "@types/vscode": "^1.108.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/test-cli": "^0.0.12",
    "npm-run-all": "^4.1.5",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.1",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
